# Copy to `.env` in this directory (`backend/`). Never commit `.env`.

# --- OpenRouter (Phase 4) ---
OPENROUTER_API_KEY=

# --- GitHub v1: PAT + repository webhook (Phase 2) ---
GITHUB_PAT=
GITHUB_WEBHOOK_SECRET=

# --- Augment Auggie SDK (Phase 5) ---
# Recommended: session JSON from the CLI (includes access token + tenant URL).
#   1. Run `auggie login` once on this machine.
#   2. Run `auggie token print` and paste the entire JSON on one line below.
# If the JSON is awkward in .env, keep it in a file and load it in code instead.
AUGMENT_SESSION_AUTH=

# Optional: only if you pass credentials explicitly to Auggie(...) instead of session auth.
# AUGMENT_API_KEY=
# AUGMENT_API_URL=

# --- Next.js dev server (Phase 0 CORS) ---
# Comma-separated if you need more than one origin:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000

# Run API from `backend/`:
#   uv run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
